#!/usr/bin/env bash
# Pre-commit quality gate: formatting, type-check, and tests must pass before a commit.
# Enable once per clone with: git config core.hooksPath .githooks
set -uo pipefail

cd "$(git rev-parse --show-toplevel)" || exit 1

run() {
  printf 'pre-commit: %s\n' "$*"
  if ! "$@"; then
    printf 'pre-commit FAILED: %s\n' "$*" >&2
    exit 1
  fi
}

run cargo fmt --all --check
# No standalone `cargo check`: `cargo test` already compiles every target (clippy ⊇ check
# covers linting at pre-push). Type errors surface here as a test build failure.
run cargo test
