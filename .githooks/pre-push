#!/usr/bin/env bash
# Pre-push gate for main: run everything CI does (ci.yml) except the release binary build.
# Mirrors the fmt / clippy / test / android-check jobs so a green local push stays green in CI.
# Enable once per clone with: git config core.hooksPath .githooks
set -uo pipefail

cd "$(git rev-parse --show-toplevel)" || exit 1

# pre-push receives "<local ref> <local sha> <remote ref> <remote sha>" lines on stdin.
pushing_main=false
while read -r _local_ref _local_sha remote_ref _remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    pushing_main=true
  fi
done

if [ "$pushing_main" != true ]; then
  exit 0
fi

run() {
  printf 'pre-push: %s\n' "$*"
  if ! "$@"; then
    printf 'pre-push FAILED: %s\n' "$*" >&2
    exit 1
  fi
}

run cargo fmt --all --check
run cargo clippy --all-targets -- -D warnings
run cargo test
run cargo check --all-targets --target aarch64-linux-android
